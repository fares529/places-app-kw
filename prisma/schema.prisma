generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Place {
  id              String   @id
  nameAr          String
  nameEn          String
  descriptionAr   String
  descriptionEn   String
  categoryId      String
  rating          Float    @default(0)
  reviewsCount    Int      @default(0)
  priceRange      Int      @default(2)
  area            String
  areaEn          String
  address         String
  addressEn       String
  phone           String?
  website         String?
  lat             Float
  lng             Float
  images          String   // JSON array
  openingHours    String
  openingHoursEn  String
  features        String   // JSON array
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  category        Category @relation(fields: [categoryId], references: [id])
  visits          Visit[]

  @@index([categoryId])
  @@index([isFeatured])
}

model Category {
  id        String   @id
  nameAr    String
  nameEn    String
  icon      String
  color     String
  bgColor   String
  places    Place[]
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  fullPhone    String
  countryCode  String
  loggedInAt   DateTime @default(now())
  createdAt    DateTime @default(now())
}

model Otp {
  id           String   @id @default(cuid())
  phone        String
  fullPhone    String
  countryCode  String
  code         String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([phone])
}

model Visit {
  id        String   @id @default(cuid())
  placeId   String
  visitedAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model AppVisit {
  id        String   @id @default(cuid())
  visitedAt DateTime @default(now())
}

model CountryVisit {
  id          String   @id @default(cuid())
  countryCode String
  visitedAt   DateTime @default(now())

  @@index([countryCode])
}
